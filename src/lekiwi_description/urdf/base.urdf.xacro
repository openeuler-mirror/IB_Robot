<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="lekiwi">

  <!-- Include robot properties -->
  <xacro:include filename="$(find lekiwi_description)/urdf/base.common.xacro"/>
  <xacro:include filename="$(find lekiwi_description)/urdf/base.control.xacro"/>

  <!-- Arguments -->
  <xacro:arg name="use_sim" default="false"/>
  <xacro:arg name="sim_plugin" default="gz_ros2_control/GazeboSimSystem"/>
  <xacro:arg name="gz_ros2_control_parameters_file" default="$(find robot_config)/config/lekiwi/lekiwi_controllers.yaml"/>
  <xacro:arg name="serial_port"  default="${serial_port}"/>
  <xacro:arg name="use_mock"     default="${use_mock}"/>
  <xacro:arg name="i2c_bus"     default="${imu_i2c_bus}"/>
  <xacro:arg name="i2c_addr"    default="${imu_i2c_addr}"/>
  <xacro:arg name="axis_remap"  default="${imu_axis_remap}"/>
  <xacro:arg name="sensor_mode" default="${imu_sensor_mode}"/>

  <!-- Define custom materials for base and wheels using color properties -->
  <material name="light_grey">
    <color rgba="${light_grey_rgba}"/>
  </material>
  <material name="charcoal">
    <color rgba="${charcoal_rgba}"/>
  </material>

  <!-- LINKS -->

  <!-- Base footprint link (empty) -->
  <link name="base_footprint"/>

  <!-- Base link -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 ${base_offset_rz}"/>
      <geometry>
        <mesh filename="package://lekiwi_description/meshes/lekiwi_base.stl"/>
      </geometry>
      <material name="light_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 ${base_offset_rz}"/>
      <geometry>
        <mesh filename="package://lekiwi_description/meshes/lekiwi_base.stl"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="2.0"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.02"/>
    </inertial>
  </link>

  <!-- LD06 laser link -->
  <link name="laser_link">
    <visual>
      <origin xyz="0 0 0" rpy="${laser_offset_rx} 0 0"/>
      <geometry>
        <mesh filename="package://lekiwi_description/meshes/ld06_lidar.stl"/>
      </geometry>
      <material name="charcoal"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="${laser_offset_rx} 0 0"/>
      <geometry>
        <mesh filename="package://lekiwi_description/meshes/ld06_lidar.stl"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>

  <!-- Laser frame -->
  <link name="laser_frame"/>

  <!-- BNO055 IMU link -->
  <link name="imu_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://lekiwi_description/meshes/bno055_imu.stl"/>
      </geometry>
      <material name="charcoal"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://lekiwi_description/meshes/bno055_imu.stl"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.00001" ixy="0.0" ixz="0.0" iyy="0.00001" iyz="0.0" izz="0.00001"/>
    </inertial>
  </link>

  <!-- IMU frame -->
  <link name="imu_frame"/>

  <!-- Camera link -->
  <link name="camera_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://lekiwi_description/meshes/hd_webcam.stl"/>
      </geometry>
      <material name="charcoal"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://lekiwi_description/meshes/hd_webcam.stl"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.00001" ixy="0.0" ixz="0.0" iyy="0.00001" iyz="0.0" izz="0.00001"/>
    </inertial>
  </link>

  <!-- Camera frame-->
  <link name="camera"/>

  <!-- Left wheel link -->
  <link name="left_wheel_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://lekiwi_description/meshes/omni_wheel.stl"/>
      </geometry>
      <material name="charcoal"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://lekiwi_description/meshes/omni_wheel.stl"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <!-- Back wheel link -->
  <link name="back_wheel_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://lekiwi_description/meshes/omni_wheel.stl"/>
      </geometry>
      <material name="charcoal"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://lekiwi_description/meshes/omni_wheel.stl"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <!-- Right wheel link -->
  <link name="right_wheel_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://lekiwi_description/meshes/omni_wheel.stl"/>
      </geometry>
      <material name="charcoal"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://lekiwi_description/meshes/omni_wheel.stl"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <!-- JOINTS -->

  <!-- base_footprint fixed joint -->
  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${wheel_radius - wheel_base_offset_z}" rpy="0 0 0"/>
  </joint>

  <!-- laser fixed joint -->
  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser_link"/>
    <origin xyz="${laser_base_offset_x} 0 ${laser_base_offset_z}" rpy="0 0 0"/>
  </joint>

  <!-- laser_frame fixed joint -->
  <joint name="laser_frame_joint" type="fixed">
    <parent link="laser_link"/>
    <child link="laser_frame"/>
    <origin xyz="0 0 ${laser_frame_offset_z}" rpy="0 0 0"/>
  </joint>

  <!-- IMU fixed joint -->
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="${imu_base_offset_x} 0 ${imu_base_offset_z}" rpy="0 0 0"/>
  </joint>

  <!-- imu_frame fixed joint -->
  <joint name="imu_frame_joint" type="fixed">
    <parent link="imu_link"/>
    <child link="imu_frame"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- camera fixed joint -->
  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="${camera_base_offset_x} 0 ${camera_base_offset_z}" rpy="0 ${camera_offset_ry} 0"/>
  </joint>

  <!-- camera_frame fixed joint -->
  <joint name="camera_frame_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera"/>
    <origin xyz="0 0 0" rpy="0 0 ${3*pi/2}"/>
  </joint>

  <!-- left wheel joint: 60 degrees anti-clockwise from +X at radius wheel_base_radius -->
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel_link"/>
    <origin xyz="${wheel_base_radius * cos(offset)} ${wheel_base_radius * sin(offset)} ${wheel_base_offset_z}" rpy="0 ${pi/2} ${offset}"/>
    <axis xyz="0 0 1"/>
    <limit effort="${max_torque_nm}" velocity="${max_velocity_rads}"/>
  </joint>

  <!-- back wheel joint: 180 degrees anti-clockwise from +X at radius base_radius -->
  <joint name="back_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="back_wheel_link"/>
    <origin xyz="${wheel_base_radius * cos(offset + theta)} ${wheel_base_radius * sin(offset + theta)} ${wheel_base_offset_z}" rpy="0 ${pi/2} ${offset + theta}"/>
    <axis xyz="0 0 1"/>
    <limit effort="${max_torque_nm}" velocity="${max_velocity_rads}"/>
  </joint>

  <!-- right wheel joint: 300 degrees (or -60 degrees) anti-clockwise from +X at radius base_radius -->
  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel_link"/>
    <origin xyz="${wheel_base_radius * cos(offset - theta)} ${wheel_base_radius * sin(offset - theta)} ${wheel_base_offset_z}" rpy="0 ${pi/2} ${offset - theta}"/>
    <axis xyz="0 0 1"/>
    <limit effort="${max_torque_nm}" velocity="${max_velocity_rads}"/>
  </joint>

  <!-- ROS 2 CONTROL -->
  <!-- System interface -->
  <ros2_control name="lekiwi_base" type="system">
    <xacro:if value="$(arg use_sim)">
      <hardware>
        <plugin>$(arg sim_plugin)</plugin>
      </hardware>
    </xacro:if>
    <xacro:unless value="$(arg use_sim)">
      <hardware>
        <plugin>sts_hardware_interface/STSHardwareInterface</plugin>
        <!-- Serial communication parameters -->
        <param name="serial_port">$(arg serial_port)</param>
        <param name="baud_rate">${baud_rate}</param>
        <param name="use_sync_write">${use_sync_write}</param>
        <param name="enable_mock_mode">$(arg use_mock)</param>
        <!-- Motor-specific parameter (adjust for different STS motor models) -->
        <param name="max_velocity_steps">${sts_max_velocity_steps}</param>
        <!-- Proportional ACC: scale per-wheel acceleration so all wheels finish ramping in equal time -->
        <param name="proportional_acc_max">${proportional_acc_max}</param>
      </hardware>
    </xacro:unless>
    <!-- Left wheel joint (Motor ID 7) -->
    <joint name="left_wheel_joint">
      <param name="motor_id">${left_motor_id}</param>
      <param name="operating_mode">${operating_mode}</param>
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
      <state_interface name="voltage"/>
      <state_interface name="temperature"/>
      <state_interface name="current"/>
      <state_interface name="is_moving"/>
    </joint>
    <!-- Back wheel joint (Motor ID 8) -->
    <joint name="back_wheel_joint">
      <param name="motor_id">${back_motor_id}</param>
      <param name="operating_mode">${operating_mode}</param>
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
      <state_interface name="voltage"/>
      <state_interface name="temperature"/>
      <state_interface name="current"/>
      <state_interface name="is_moving"/>
    </joint>
    <!-- Right wheel joint (Motor ID 9) -->
    <joint name="right_wheel_joint">
      <param name="motor_id">${right_motor_id}</param>
      <param name="operating_mode">${operating_mode}</param>
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
      <state_interface name="voltage"/>
      <state_interface name="temperature"/>
      <state_interface name="current"/>
      <state_interface name="is_moving"/>
    </joint>
  </ros2_control>

  <!-- ROS 2 CONTROL -->
  <!-- Sensor interface (BNO055 IMU) -->
  <xacro:unless value="$(arg use_sim)">
    <ros2_control name="lekiwi_imu" type="sensor">
      <hardware>
        <plugin>bno055_hardware_interface/BNO055HardwareInterface</plugin>
        <param name="i2c_bus">$(arg i2c_bus)</param>       <!-- I2C bus number (default: 1 → /dev/i2c-1) -->
        <param name="i2c_addr">$(arg i2c_addr)</param>     <!-- I2C address in hex, no 0x prefix (default: 28 = 0x28) -->
        <param name="axis_remap">$(arg axis_remap)</param> <!-- Axis placement config: P0-P7 (default: P1) -->
        <param name="sensor_mode">$(arg sensor_mode)</param> <!-- Fusion mode: NDOF, NDOF_FMC_OFF, IMUPLUS (default: NDOF) -->
        <param name="enable_mock">$(arg use_mock)</param>  <!-- Reuse the system-level mock flag -->
      </hardware>
      <sensor name="bno055">
        <!-- Orientation (quaternion, unit norm) -->
        <state_interface name="orientation.x"/>
        <state_interface name="orientation.y"/>
        <state_interface name="orientation.z"/>
        <state_interface name="orientation.w"/>
        <!-- Angular velocity (rad/s) -->
        <state_interface name="angular_velocity.x"/>
        <state_interface name="angular_velocity.y"/>
        <state_interface name="angular_velocity.z"/>
        <!-- Linear acceleration (m/s²), gravity-compensated -->
        <state_interface name="linear_acceleration.x"/>
        <state_interface name="linear_acceleration.y"/>
        <state_interface name="linear_acceleration.z"/>
      </sensor>
    </ros2_control>
  </xacro:unless>

  <xacro:if value="$(arg use_sim)">
    <gazebo>
      <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
        <parameters>$(arg gz_ros2_control_parameters_file)</parameters>
      </plugin>
    </gazebo>

    <gazebo reference="camera">
      <sensor type="camera" name="front_camera">
        <always_on>true</always_on>
        <update_rate>15</update_rate>
        <topic>/front_camera/image</topic>
        <camera>
          <horizontal_fov>1.3121</horizontal_fov>
          <image>
            <width>640</width>
            <height>480</height>
            <format>R8G8B8</format>
          </image>
          <clip>
            <near>0.01</near>
            <far>100.0</far>
          </clip>
        </camera>
      </sensor>
    </gazebo>

    <gazebo reference="laser_frame">
      <sensor type="gpu_lidar" name="front_lidar">
        <always_on>true</always_on>
        <update_rate>15</update_rate>
        <topic>/scan</topic>
        <ray>
          <scan>
            <horizontal>
              <samples>360</samples>
              <resolution>1</resolution>
              <min_angle>-3.141592653589793</min_angle>
              <max_angle>3.141592653589793</max_angle>
            </horizontal>
          </scan>
          <range>
            <min>0.02</min>
            <max>12.0</max>
            <resolution>0.01</resolution>
          </range>
        </ray>
      </sensor>
    </gazebo>

    <gazebo reference="imu_frame">
      <sensor type="imu" name="sim_imu">
        <always_on>true</always_on>
        <update_rate>100</update_rate>
        <topic>/imu_sensor_broadcaster/imu</topic>
      </sensor>
    </gazebo>
  </xacro:if>

</robot>
