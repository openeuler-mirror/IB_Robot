[submodule "libs/lerobot"]
    path = libs/lerobot
    url = https://gitcode.com/openharmony-robot/lerobot.git
    ignore = dirty
[submodule "src/pymoveit2"]
	path = src/pymoveit2
	url = https://github.com/AndrejOrsula/pymoveit2.git
    branch = main
    ignore = dirty
[submodule "src/rosclaw"]
	path = src/rosclaw
	url = https://github.com/PlaiPin/rosclaw
[submodule "src/omni_wheel_controller"]
	path = src/omni_wheel_controller
	url = https://github.com/hijimasa/omni_wheel_controller
	branch = main
	ignore = dirty
