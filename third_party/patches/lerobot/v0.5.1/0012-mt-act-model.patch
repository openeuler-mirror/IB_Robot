+#
+# Unless required by applicable law or agreed to in writing, software
+# distributed under the License is distributed on an "AS IS" BASIS,
+# WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.
+# See the License for the specific language governing permissions and
+# limitations under the License.
+
+from dataclasses import dataclass, field, fields
+
+from lerobot.configs.policies import PreTrainedConfig
+from lerobot.configs.types import NormalizationMode
+from lerobot.optim.optimizers import AdamWConfig
+
+
+@dataclass
+class FilmConfig:
+    """FiLM (Feature-wise Linear Modulation) 的配置类"""
+
+    use: bool = True  # 是否在该配置实例中启用FiLM
+    use_in_layers: list[int] = field(
+        default_factory=lambda: [0, 1, 2, 3]  # 对应 layer2, layer3, layer4
+    )
+    task_embedding_dim: int = 2048  # 必须与MTACTConfig中的dim_model相同
+    film_planes: list[int] = field(
+        default_factory=lambda: [64, 128, 256, 512]  # 每层的通道数
+    )
+    append_object_mask: bool | None = None  # 是否添加物体掩码作为额外输入通道
+
+
+@PreTrainedConfig.register_subclass("mt_act")
+@dataclass
+class MTACTConfig(PreTrainedConfig):
+    # 继承ACT的基础配置
+    n_obs_steps: int = 1
+    chunk_size: int = 100
+    n_action_steps: int = 100
+
+    normalization_mapping: dict[str, NormalizationMode] = field(
+        default_factory=lambda: {
+            "VISUAL": NormalizationMode.MEAN_STD,
+            "STATE": NormalizationMode.MEAN_STD,
+            "ACTION": NormalizationMode.MEAN_STD,
+        }
+    )
+
+    # 视觉骨干网络配置
+    vision_backbone: str = "resnet18"
+    pretrained_backbone_weights: str | None = "ResNet18_Weights.IMAGENET1K_V1"
+    replace_final_stride_with_dilation: bool = False
+
+    # Transformer配置
+    pre_norm: bool = False
+    dim_model: int = 2048
+    n_heads: int = 8
+    dim_feedforward: int = 3200
+    feedforward_activation: str = "relu"
+    n_encoder_layers: int = 4
+    n_decoder_layers: int = 7
+
+    # VAE配置
+    use_vae: bool = True
+    latent_dim: int = 32
+    n_vae_encoder_layers: int = 4
+
+    # 推理配置
+    temporal_ensemble_coeff: float | None = None
+    left_act_num: int | None = 90
+
+    # 训练配置
+    dropout: float = 0.1
+    kl_weight: float = 10.0
+    optimizer_lr: float = 1e-5
+    optimizer_weight_decay: float = 1e-4
+    optimizer_lr_backbone: float = 1e-5
+
+    # 新增：语言模型配置
+    use_language: bool = True
+    task_emb_dim: int = 384  # task_embedding初始维度
+    use_film: bool = True  # 是否使用FiLM
+
+    # 初始化FilmConfig实例
+    film_config: FilmConfig = field(default_factory=FilmConfig)
+
+    # Knowledge distillation from a pretrained model.
+    kd: bool = False  # Whether to use knowledge distillation during training.
+    teacher_train_config: str | None = None  # Path to the teacher model's train_config.json
+    decoder_out_dim: int = 1024  # Dimension of the decoder output used in the distillation.
+
+    def __post_init__(self):
+        super().__post_init__()
+        if isinstance(self.film_config, dict):
+            # 获取 FilmConfig 所有合法的字段名
+            valid_film_fields = {f.name for f in fields(FilmConfig)}
+            # 过滤字典，只保留合法字段（防止旧配置中含有废弃参数）
+            filtered_dict = {k: v for k, v in self.film_config.items() if k in valid_film_fields}
+            # 重新实例化为 FilmConfig 对象
+            self.film_config = FilmConfig(**filtered_dict)
+        # 输入验证
+        if not self.vision_backbone.startswith("resnet"):
+            raise ValueError(
+                f"`vision_backbone` must be one of the ResNet variants. Got {self.vision_backbone}."
+            )
+        if self.temporal_ensemble_coeff is not None and self.n_action_steps > 1:
+            raise NotImplementedError("`n_action_steps` must be 1 when using temporal ensembling.")
+        if self.n_action_steps > self.chunk_size:
+            raise ValueError(
+                f"`n_action_steps` ({self.n_action_steps}) must be <= `chunk_size` ({self.chunk_size})."
+            )
+        if self.n_obs_steps != 1:
+            raise ValueError(
+                f"Multiple observation steps not handled yet. Got `n_obs_steps={self.n_obs_steps}`"
+            )
+        # FiLM相关验证（仅在use_film为True时执行）
+        if self.use_film:
+            # 1. 确保film_config.use也是True
+            if not self.film_config.use:
+                raise ValueError("When `use_film` is True, `film_config.use` must also be True")
+
+            # 2. 验证task_embedding_dim与dim_model匹配
+            if self.film_config.task_embedding_dim != self.dim_model:
+                raise ValueError(
+                    f"`film_config.task_embedding_dim` ({self.film_config.task_embedding_dim}) "
+                    f"must be equal to `dim_model` ({self.dim_model}) when using FiLM"
+                )
+
+            # 3. 验证use_in_layers是否为有效索引
+            max_layer_idx = len(self.film_config.film_planes) - 1
+            for layer in self.film_config.use_in_layers:
+                if layer < 0 or layer > max_layer_idx:
+                    raise ValueError(
+                        f"Invalid layer index {layer} in `film_config.use_in_layers`. "
+                        f"Must be between 0 and {max_layer_idx} (inclusive)."
+                    )
+
+    def get_optimizer_preset(self) -> AdamWConfig:
+        return AdamWConfig(
+            lr=self.optimizer_lr,
+            weight_decay=self.optimizer_weight_decay,
+        )
+
+    def get_scheduler_preset(self) -> None:
+        return None
+
+    def validate_features(self) -> None:
+        if not self.image_features and not self.env_state_feature and not self.use_language:
+            raise ValueError("You must provide at least one image, environment state, or language input.")
+
+    @property
+    def observation_delta_indices(self) -> None:
+        return None
+
+    @property
+    def action_delta_indices(self) -> list:
+        return list(range(self.chunk_size))
+
+    @property
+    def reward_delta_indices(self) -> None:
+        return None
