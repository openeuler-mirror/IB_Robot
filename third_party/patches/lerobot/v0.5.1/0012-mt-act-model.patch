diff --git a/src/lerobot/policies/mt_act/modeling_mt_act.py b/src/lerobot/policies/mt_act/modeling_mt_act.py
new file mode 100644
index 00000000..52348a14
--- /dev/null
+++ b/src/lerobot/policies/mt_act/modeling_mt_act.py
@@ -0,0 +1,736 @@
+#!/usr/bin/env python
+
+# Copyright 2024 The HuggingFace Inc. team. All rights reserved.
+# Licensed under the Apache License, Version 2.0 (the "License")
+
+import math
+from collections import deque
+from collections.abc import Callable
+from itertools import chain
+from typing import Any
+
+import einops
+import numpy as np
+import torch
+import torch.nn.functional as f
+import torchvision
+from torch import Tensor, nn
+from torchvision.models._utils import IntermediateLayerGetter
+
+# LeRobot 内部组件
+from lerobot.policies.act.processor_act import make_act_pre_post_processors
+from lerobot.policies.mt_act.configuration_mt_act import MTACTConfig
+from lerobot.policies.mt_act.constants import task_to_embedding
+from lerobot.policies.mt_act.resnet_film import ResNetFilmBackbone
+from lerobot.policies.pretrained import PreTrainedPolicy
+from lerobot.processor.converters import batch_to_transition
+from lerobot.utils.constants import ACTION, OBS_ENV_STATE, OBS_IMAGES, OBS_STATE
+
+
+class MTACTPolicy(PreTrainedPolicy):
+    """
+    Multimodal Action Chunking Transformer Policy.
+    精简版：同步推理，标准队列管理，无平滑，支持语言与掩码。
+    """
+
+    config_class = MTACTConfig
+    name = "mt_act"
+
+    def __init__(self, config: MTACTConfig):
+        super().__init__(config)
+        config.validate_features()
+        self.config = config
+
+        # 1. 核心模型初始化
+        self.model = MTACT(config)
+
+        # 2. 标准动作队列
+        self._action_queue = deque([], maxlen=self.config.n_action_steps)
+
+        self.reset()
+
+    def reset(self):
+        """环境重置时调用"""
+        self._action_queue.clear()
+
+    def get_optim_params(self) -> list[dict]:
+        return [
+            {
+                "params": [
+                    p for n, p in self.named_parameters() if "model.backbone" not in n and p.requires_grad
+                ]
+            },
+            {
+                "params": [
+                    p for n, p in self.named_parameters() if "model.backbone" in n and p.requires_grad
+                ],
+                "lr": self.config.optimizer_lr_backbone,
+            },
+        ]
+
+    @torch.no_grad()
+    def select_action(self, batch: dict[str, Tensor]) -> Tensor:
+        """选择动作的核心入口"""
+        self.eval()
+
+        # A. 语言预处理
+        if self.config.use_language and "task" in batch:
+            device = batch[OBS_STATE].device
+            encoded_text = self.model.encode_text(batch["task"]).to(device)
+            batch["language_features"] = encoded_text
+
+        # B. 队列逻辑：如果队列空了，同步推理填充 Chunk
+        if len(self._action_queue) == 0:
+            # 推理获得 (Batch, Chunk, Action_Dim)
+            actions_chunk = self.predict_action_chunk(batch)
+
+            # 截取需要执行的步数 (n_action_steps)
+            # 转置为 (Chunk, Batch, Action_Dim) 放入队列
+            actions_to_queue = actions_chunk[:, : self.config.n_action_steps]
+            self._action_queue.extend(actions_to_queue.transpose(0, 1))
+
+        # C. 从队列弹出一个动作
+        action = self._action_queue.popleft()
+
+        if action.ndim == 2:
+            action = action.squeeze(0)
+
+        return action
+
+    @torch.no_grad()
+    def predict_action_chunk(self, batch: dict[str, Tensor]) -> Tensor:
+        """同步推理核心逻辑"""
+        if self.config.image_features:
+            batch = dict(batch)
+            # 这里的 batch[OBS_IMAGES] 供 MTACT.forward 使用
+            batch[OBS_IMAGES] = [batch[key] for key in self.config.image_features]
+
+        # 确保语言特征存在
+        if self.config.use_language and "task" in batch and "language_features" not in batch:
+            batch["language_features"] = self.model.encode_text(batch["task"]).to(batch[OBS_STATE].device)
+
+        actions, _, _, _ = self.model(batch)
+        return actions
+
+    def forward(self, batch: dict[str, Tensor]) -> tuple[Tensor, dict]:
+        """训练前向逻辑"""
+        if self.config.image_features:
+            batch = dict(batch)
+            batch[OBS_IMAGES] = [batch[key] for key in self.config.image_features]
+
+        if self.config.use_language and "task" in batch:
+            batch["language_features"] = self.model.encode_text(batch["task"]).to(batch[ACTION].device)
+
+        actions_hat, (mu_hat, log_sigma_x2_hat), _, _ = self.model(batch)
+
+        l1_loss = (
+            f.l1_loss(batch[ACTION], actions_hat, reduction="none") * ~batch["action_is_pad"].unsqueeze(-1)
+        ).mean()
+        loss_dict = {"l1_loss": l1_loss.item()}
+
+        if self.config.use_vae and self.training:
+            mean_kld = (-0.5 * (1 + log_sigma_x2_hat - mu_hat.pow(2) - log_sigma_x2_hat.exp())).sum(-1).mean()
+            loss_dict["kld_loss"] = mean_kld.item()
+            loss = l1_loss + mean_kld * self.config.kl_weight
+        else:
+            loss = l1_loss
+        return loss, loss_dict
+
+
+def make_mt_act_pre_post_processors(config, dataset_stats=None):
+    """
+    专门为 MTACT 定义的处理器工厂。
+    采用极其稳健的字典拼装逻辑，防止由于 'task' 字符串导致的拼装失败。
+    """
+    # 1. 正常调用标准的 ACT 处理器工厂
+
+    preprocessor, postprocessor = make_act_pre_post_processors(config, dataset_stats)
+
+    # 2. 定义高度防御性的转换逻辑
+    def list_safe_to_transition(data):
+        # 如果数据是列表（DataLoader 没拼好的情况）
+        if isinstance(data, list):
+            # 防御检查：如果列表为空
+            if len(data) == 0:
+                return batch_to_transition({})
+
+            # 如果列表里的第一个元素就不是字典，说明数据流彻底乱了，打印诊断信息
+            if not isinstance(data[0], dict):
+                # 这种情况直接尝试转 Tensor 可能会报错，但能看到真实类型
+                return batch_to_transition(data)
+
+            # 稳健的手动拼装逻辑：先把列表转为 Dict[str, List]
+            collated = {}
+            # 我们先遍历第一个元素的所有 Key
+            for key in data[0]:
+                # 使用最原始的循环，不使用列表推导式，方便排错
+                val_list = []
+                for item in data:
+                    # 确保 item 是字典且包含该 key，否则跳过
+                    if isinstance(item, dict) and key in item:
+                        val_list.append(item[key])
+
+                if not val_list:
+                    continue
+
+                # 情况 A: 处理 Tensor
+                if isinstance(val_list[0], torch.Tensor):
+                    # 检查是否为标量或维度不一，stack 前做安全处理
+                    collated[key] = torch.stack(val_list)
+
+                # 情况 B: 处理 NumPy
+                elif isinstance(val_list[0], np.ndarray):
+                    collated[key] = torch.from_numpy(np.stack(val_list))
+
+                # 情况 C: 处理字符串 (task) 或其他
+                else:
+                    collated[key] = val_list
+
+            data = collated
+
+        # 此时 data 必须是一个 dict，交给官方转换器转成 EnvTransition 对象
+        return batch_to_transition(data)
+
+    # 3. 覆盖 preprocessor 的转换器
+    preprocessor.to_transition = list_safe_to_transition
+
+    return preprocessor, postprocessor
+
+
+class MTACT(nn.Module):
+    """MTACT 神经网络主体"""
+
+    def __init__(self, config: MTACTConfig):
+        super().__init__()
+        self.config = config
+
+        # 1. VAE 编码器
+        if self.config.use_vae:
+            self.vae_encoder = ACTEncoder(config, is_vae_encoder=True)
+            self.vae_encoder_cls_embed = nn.Embedding(1, config.dim_model)
+            if self.config.robot_state_feature:
+                self.vae_encoder_robot_state_input_proj = nn.Linear(
+                    config.robot_state_feature.shape[0], config.dim_model
+                )
+            self.vae_encoder_action_input_proj = nn.Linear(config.action_feature.shape[0], config.dim_model)
+            self.vae_encoder_latent_output_proj = nn.Linear(config.dim_model, config.latent_dim * 2)
+            n_vae_tokens = 1 + config.chunk_size + (1 if config.robot_state_feature else 0)
+            self.register_buffer(
+                "vae_encoder_pos_enc",
+                create_sinusoidal_pos_embedding(n_vae_tokens, config.dim_model).unsqueeze(0),
+            )
+
+        # 2. 视觉骨干网络
+        if self.config.image_features:
+            if self.config.use_film:
+                self.backbone = ResNetFilmBackbone(
+                    vision_backbone=config.vision_backbone,
+                    pretrained_backbone_weights=config.pretrained_backbone_weights,
+                    film_config=config.film_config,
+                    dim_model=config.dim_model,
+                )
+            else:
+                backbone_model = getattr(torchvision.models, config.vision_backbone)(
+                    weights=config.pretrained_backbone_weights
+                )
+                self.backbone = IntermediateLayerGetter(
+                    backbone_model, return_layers={"layer4": "feature_map"}
+                )
+
+        # 3. Transformer 核心
+        self.encoder = ACTEncoder(config)
+        self.decoder = ACTDecoder(config)
+
+        # 4. 投影层
+        self.encoder_latent_input_proj = nn.Linear(config.latent_dim, config.dim_model)
+        if self.config.robot_state_feature:
+            self.encoder_robot_state_input_proj = nn.Linear(
+                config.robot_state_feature.shape[0], config.dim_model
+            )
+        if self.config.env_state_feature:
+            self.encoder_env_state_input_proj = nn.Linear(config.env_state_feature.shape[0], config.dim_model)
+        if self.config.use_language:
+            self.encoder_language_input_proj = nn.Linear(config.task_emb_dim, config.dim_model)
+
+        if self.config.image_features:
+            # 自动获取输入维度
+            if self.config.use_film:
+                in_features = self.backbone._fc_in_features
+            else:
+                in_features = 512 if self.config.vision_backbone in ["resnet18", "resnet34"] else 2048
+
+            self.encoder_img_feat_input_proj = nn.Conv2d(in_features, config.dim_model, kernel_size=1)
+            self.encoder_cam_feat_pos_embed = ACTSinusoidalPositionEmbedding2d(config.dim_model // 2)
+
+        # 5. 位置编码与输出头
+        n_1d_tokens = (
+            1
+            + (1 if config.robot_state_feature else 0)
+            + (1 if config.env_state_feature else 0)
+            + (1 if config.use_language else 0)
+        )
+        self.encoder_1d_feature_pos_embed = nn.Embedding(n_1d_tokens, config.dim_model)
+        self.decoder_pos_embed = nn.Embedding(config.chunk_size, config.dim_model)
+        self.action_head = nn.Linear(config.dim_model, config.action_feature.shape[0])
+
+        self._reset_parameters()
+
+    def _reset_parameters(self):
+        for p in chain(self.encoder.parameters(), self.decoder.parameters()):
+            if p.dim() > 1:
+                nn.init.xavier_uniform_(p)
+
+    def encode_text(self, texts: list[Any]) -> Tensor:
+        """
+        将任务名列表映射为 embedding 张量。
+        增加稳健性处理：自动处理嵌套列表 (List of List)。
+        """
+        processed_texts = []
+        for t in texts:
+            temp_t = t
+            # 如果 t 是 ['pick up the box'] 这种嵌套列表，取第一个元素
+            while isinstance(temp_t, list) and len(temp_t) > 0:
+                temp_t = temp_t[0]
+
+            if not isinstance(temp_t, str):
+                temp_t = str(temp_t)
+
+            processed_texts.append(temp_t)
+
+        emb_list = []
+        for t in processed_texts:
+            # 获取 Embedding
+            emb = task_to_embedding(t)
+
+            if emb is None:
+                raise ValueError(
+                    f"Task description '{t}' not found in task_to_embedding_dict. Please check constants.py"
+                )
+
+            if not isinstance(emb, torch.Tensor):
+                emb = torch.tensor(emb, dtype=torch.float32)
+
+            if emb.device.type == "cuda":
+                emb = emb.detach().cpu()
+
+            emb_list.append(emb)
+
+        # 堆叠所有嵌入向量
+        emb = torch.stack(emb_list, dim=0)
+
+        # 计算每行的均值和标准差进行标准化
+        mean = torch.mean(emb, dim=1, keepdim=True)
+        std = torch.std(emb, dim=1, keepdim=True)
+        safe_std = torch.max(std, torch.tensor(1e-8))
+
+        return (emb - mean) / safe_std
+
+    def get_feature_map_size(self):
+        if hasattr(self, "_cached_f_size") and self._cached_f_size:
+            return self._cached_f_size
+        return (7, 7)
+
+    def forward(
+        self,
+        batch: dict[str, Tensor],
+        attention_mask: Tensor | None = None,
+        encoder_key_padding_mask: Tensor | None = None,
+    ) -> tuple[Tensor, tuple[Tensor, Tensor] | tuple[None, None], Tensor | None, Tensor]:
+        """
+        MTACT 前向传播 (方案 A: VAE 不包含图像)
+        处理 LeRobot 的 (Batch, Time, ...) 格式数据
+        """
+        device = batch[OBS_STATE].device
+        # LeRobot 传进来的 batch[OBS_STATE] 通常是 (B, T, D)
+        batch_size = batch[OBS_STATE].shape[0]
+
+        # --- 1. VAE 潜在变量处理 (仅训练阶段) ---
+        if self.config.use_vae and ACTION in batch and self.training:
+            # A. CLS Token: (B, 1, D)
+            cls_embed = einops.repeat(self.vae_encoder_cls_embed.weight, "1 d -> b 1 d", b=batch_size)
+            vae_encoder_input = [cls_embed]
+
+            # B. Robot State: 取最后一帧
+            if self.config.robot_state_feature:
+                curr_state = batch[OBS_STATE]
+                if curr_state.ndim == 3:
+                    curr_state = curr_state[:, -1]  # (B, T, D) -> (B, D)
+
+                # 投影后 (B, D) -> unsqueeze(1) 变成 (B, 1, D)
+                res_state_embed = self.vae_encoder_robot_state_input_proj(curr_state).unsqueeze(1)
+                vae_encoder_input.append(res_state_embed)
+
+            # C. Action Sequence: 已经是 (B, Chunk_Size, Action_Dim)
+            # 投影后 (B, Chunk_Size, D)
+            action_embed = self.vae_encoder_action_input_proj(batch[ACTION])
+            vae_encoder_input.append(action_embed)
+
+            vae_encoder_input = torch.cat(vae_encoder_input, axis=1)
+
+            pos_embed = self.vae_encoder_pos_enc.clone().detach()
+
+            # cls(False), state(False), actions(根据 batch)
+            cls_joint_is_pad = torch.full(
+                (batch_size, 2 if self.config.robot_state_feature else 1),
+                False,
+                device=device,
+            )
+            vae_key_padding_mask = torch.cat([cls_joint_is_pad, batch["action_is_pad"]], axis=1)
+
+            # VAE 编码 (Sequence First: L, B, D)
+            res = self.vae_encoder(
+                vae_encoder_input.permute(1, 0, 2),
+                pos_embed=pos_embed.permute(1, 0, 2),
+                key_padding_mask=vae_key_padding_mask,
+            )
+            cls_token_out = res[0]  # 提取 CLS token 的输出
+
+            latent_pdf_params = self.vae_encoder_latent_output_proj(cls_token_out)
+            mu = latent_pdf_params[:, : self.config.latent_dim]
+            log_sigma_x2 = latent_pdf_params[:, self.config.latent_dim :]
+            latent_sample = mu + log_sigma_x2.div(2).exp() * torch.randn_like(mu)
+        else:
+            mu = log_sigma_x2 = None
+            latent_sample = torch.zeros(
+                [batch_size, self.config.latent_dim], dtype=torch.float32, device=device
+            )
+
+        encoder_in_tokens = []
+        encoder_in_pos_embed = []
+        p_idx = 0
+
+        # Latent Token (B, D) -> (1, B, D)
+        latent_token = self.encoder_latent_input_proj(latent_sample).unsqueeze(0)
+        encoder_in_tokens.append(latent_token)
+        encoder_in_pos_embed.append(self.encoder_1d_feature_pos_embed.weight[p_idx].view(1, 1, -1))
+        p_idx += 1
+
+        # Robot State Token: 取最后一帧
+        if self.config.robot_state_feature:
+            curr_state = batch[OBS_STATE]
+            if curr_state.ndim == 3:
+                curr_state = curr_state[:, -1]
+            state_token = self.encoder_robot_state_input_proj(curr_state).unsqueeze(0)
+            encoder_in_tokens.append(state_token)
+            encoder_in_pos_embed.append(self.encoder_1d_feature_pos_embed.weight[p_idx].view(1, 1, -1))
+            p_idx += 1
+
+        # Env State Token: 取最后一帧
+        if self.config.env_state_feature:
+            curr_env = batch[OBS_ENV_STATE]
+            if curr_env.ndim == 3:
+                curr_env = curr_env[:, -1]
+            env_token = self.encoder_env_state_input_proj(curr_env).unsqueeze(0)
+            encoder_in_tokens.append(env_token)
+            encoder_in_pos_embed.append(self.encoder_1d_feature_pos_embed.weight[p_idx].view(1, 1, -1))
+            p_idx += 1
+
+        # Language Token (FiLM 调制基础)
+        lang_emb = None
+        if self.config.use_language and "language_features" in batch:
+            lang_token = self.encoder_language_input_proj(batch["language_features"])
+            lang_emb = lang_token
+            encoder_in_tokens.append(lang_token.unsqueeze(0))
+            encoder_in_pos_embed.append(self.encoder_1d_feature_pos_embed.weight[p_idx].view(1, 1, -1))
+            p_idx += 1
+
+        # 图像特征只在主 Encoder 中使用
+        if self.config.image_features:
+            for img in batch[OBS_IMAGES]:
+                # 如果 LeRobot 提供视频序列 (B, T, C, H, W)，取最后一帧
+                if img.ndim == 5:
+                    img = img[:, -1]
+
+                # Backbone 提取特征图 (B, C, H, W)
+                if self.config.use_film:
+                    features = self.backbone(img, task_emb=lang_emb)["feature_map"]
+                else:
+                    features = self.backbone(img)["feature_map"]
+
+                self._cached_f_size = features.shape[-2:]
+
+                # 位置编码
+                pos = self.encoder_cam_feat_pos_embed(features)
+                # 投影到模型维度 (B, D, H, W)
+                proj_features = self.encoder_img_feat_input_proj(features)
+
+                # (B, D, H, W) -> (H*W, B, D)
+                encoder_in_tokens.append(einops.rearrange(proj_features, "b c h w -> (h w) b c"))
+                encoder_in_pos_embed.append(einops.rearrange(pos, "b c h w -> (h w) b c"))
+
+        # 合并所有 Tokens (Sequence First: S, B, D)
+        encoder_in_tokens = torch.cat(encoder_in_tokens, dim=0)
+        encoder_in_pos_embed = torch.cat(encoder_in_pos_embed, dim=0)
+
+        # Encoder
+        encoder_out = self.encoder(
+            encoder_in_tokens, pos_embed=encoder_in_pos_embed, key_padding_mask=encoder_key_padding_mask
+        )
+
+        # Decoder (全 0 Query)
+        decoder_in = torch.zeros(
+            (self.config.chunk_size, batch_size, self.config.dim_model),
+            dtype=encoder_in_pos_embed.dtype,
+            device=device,
+        )
+        decoder_out, all_cross_attn_weights = self.decoder(
+            decoder_in,
+            encoder_out,
+            encoder_pos_embed=encoder_in_pos_embed,
+            decoder_pos_embed=self.decoder_pos_embed.weight.unsqueeze(1),
+            attention_mask=attention_mask,
+        )
+
+        decoder_out = decoder_out.transpose(0, 1)  # (B, Chunk, D)
+        actions = self.action_head(decoder_out)
+
+        return actions, (mu, log_sigma_x2), all_cross_attn_weights, decoder_out
+
+
+class ACTEncoder(nn.Module):
+    """Convenience module for running multiple encoder layers, maybe followed by normalization."""
+
+    def __init__(self, config: MTACTConfig, is_vae_encoder: bool = False):
+        super().__init__()
+        self.is_vae_encoder = is_vae_encoder
+        num_layers = config.n_vae_encoder_layers if self.is_vae_encoder else config.n_encoder_layers
+        self.layers = nn.ModuleList([ACTEncoderLayer(config) for _ in range(num_layers)])
+        self.norm = nn.LayerNorm(config.dim_model) if config.pre_norm else nn.Identity()
+
+    def forward(
+        self, x: Tensor, pos_embed: Tensor | None = None, key_padding_mask: Tensor | None = None
+    ) -> Tensor:
+        for layer in self.layers:
+            x = layer(x, pos_embed=pos_embed, key_padding_mask=key_padding_mask)
+        x = self.norm(x)
+        return x
+
+
+class ACTEncoderLayer(nn.Module):
+    def __init__(self, config: MTACTConfig):
+        super().__init__()
+        self.self_attn = nn.MultiheadAttention(config.dim_model, config.n_heads, dropout=config.dropout)
+
+        # Feed forward layers.
+        self.linear1 = nn.Linear(config.dim_model, config.dim_feedforward)
+        self.dropout = nn.Dropout(config.dropout)
+        self.linear2 = nn.Linear(config.dim_feedforward, config.dim_model)
+
+        self.norm1 = nn.LayerNorm(config.dim_model)
+        self.norm2 = nn.LayerNorm(config.dim_model)
+        self.dropout1 = nn.Dropout(config.dropout)
+        self.dropout2 = nn.Dropout(config.dropout)
+
+        self.activation = get_activation_fn(config.feedforward_activation)
+        self.pre_norm = config.pre_norm
+
+    def forward(self, x, pos_embed: Tensor | None = None, key_padding_mask: Tensor | None = None) -> Tensor:
+        skip = x
+        if self.pre_norm:
+            x = self.norm1(x)
+        q = k = x if pos_embed is None else x + pos_embed
+        x = self.self_attn(q, k, value=x, key_padding_mask=key_padding_mask)
+        x = x[0]  # note: [0] to select just the output, not the attention weights
+        x = skip + self.dropout1(x)
+        if self.pre_norm:
+            skip = x
+            x = self.norm2(x)
+        else:
+            x = self.norm1(x)
+            skip = x
+        x = self.linear2(self.dropout(self.activation(self.linear1(x))))
+        x = skip + self.dropout2(x)
+        if not self.pre_norm:
+            x = self.norm2(x)
+        return x
+
+
+class ACTDecoder(nn.Module):
+    def __init__(self, config: MTACTConfig):
+        """Convenience module for running multiple decoder layers followed by normalization."""
+        super().__init__()
+        self.layers = nn.ModuleList([ACTDecoderLayer(config) for _ in range(config.n_decoder_layers)])
+        self.norm = nn.LayerNorm(config.dim_model)
+
+    def forward(
+        self,
+        x: Tensor,
+        encoder_out: Tensor,
+        decoder_pos_embed: Tensor | None = None,
+        encoder_pos_embed: Tensor | None = None,
+        attention_mask: Tensor | None = None,
+    ) -> tuple[Tensor, Tensor]:
+        all_cross_attn_weights = []
+        for layer in self.layers:
+            x, cross_attn_weights = layer(
+                x,
+                encoder_out,
+                decoder_pos_embed=decoder_pos_embed,
+                encoder_pos_embed=encoder_pos_embed,
+                attention_mask=attention_mask,
+            )
+            all_cross_attn_weights.append(cross_attn_weights)
+        if self.norm is not None:
+            x = self.norm(x)
+        return x, torch.stack(all_cross_attn_weights, dim=0)
+
+
+class ACTDecoderLayer(nn.Module):
+    def __init__(self, config: MTACTConfig):
+        super().__init__()
+        self.self_attn = nn.MultiheadAttention(config.dim_model, config.n_heads, dropout=config.dropout)
+        self.multihead_attn = nn.MultiheadAttention(
+            config.dim_model, config.n_heads, dropout=config.dropout, batch_first=False
+        )
+
+        # Feed forward layers.
+        self.linear1 = nn.Linear(config.dim_model, config.dim_feedforward)
+        self.dropout = nn.Dropout(config.dropout)
+        self.linear2 = nn.Linear(config.dim_feedforward, config.dim_model)
+
+        self.norm1 = nn.LayerNorm(config.dim_model)
+        self.norm2 = nn.LayerNorm(config.dim_model)
+        self.norm3 = nn.LayerNorm(config.dim_model)
+        self.dropout1 = nn.Dropout(config.dropout)
+        self.dropout2 = nn.Dropout(config.dropout)
+        self.dropout3 = nn.Dropout(config.dropout)
+
+        self.activation = get_activation_fn(config.feedforward_activation)
+        self.pre_norm = config.pre_norm
+
+    def maybe_add_pos_embed(self, tensor: Tensor, pos_embed: Tensor | None) -> Tensor:
+        return tensor if pos_embed is None else tensor + pos_embed
+
+    def forward(
+        self,
+        x: Tensor,
+        encoder_out: Tensor,
+        decoder_pos_embed: Tensor | None = None,
+        encoder_pos_embed: Tensor | None = None,
+        attention_mask: Tensor | None = None,
+    ) -> tuple[Tensor, Tensor]:
+        """
+        Args:
+            x: (Decoder Sequence, Batch, Channel) tensor of input tokens.
+            encoder_out: (Encoder Sequence, B, C) output features from the last layer of the encoder we are
+                cross-attending with.
+            encoder_pos_embed: (ES, 1, C) positional embedding for keys (from the encoder).
+            decoder_pos_embed: (DS, 1, C) positional embedding for the queries (from the decoder).
+        Returns:
+            (DS, B, C) tensor of decoder output features.
+        """
+        skip = x
+        if self.pre_norm:
+            x = self.norm1(x)
+        q = k = self.maybe_add_pos_embed(x, decoder_pos_embed)
+        x = self.self_attn(q, k, value=x)[0]  # select just the output, not the attention weights
+        x = skip + self.dropout1(x)
+        if self.pre_norm:
+            skip = x
+            x = self.norm2(x)
+        else:
+            x = self.norm1(x)
+            skip = x
+        cross_attn_out, cross_attn_weights = self.multihead_attn(
+            query=self.maybe_add_pos_embed(x, decoder_pos_embed),
+            key=self.maybe_add_pos_embed(encoder_out, encoder_pos_embed),
+            value=encoder_out,
+            attn_mask=attention_mask,
+            need_weights=True,
+            average_attn_weights=False,
+        )
+        x = skip + self.dropout2(cross_attn_out)
+        if self.pre_norm:
+            skip = x
+            x = self.norm3(x)
+        else:
+            x = self.norm2(x)
+            skip = x
+        x = self.linear2(self.dropout(self.activation(self.linear1(x))))
+        x = skip + self.dropout3(x)
+        if not self.pre_norm:
+            x = self.norm3(x)
+        return x, cross_attn_weights
+
+
+def create_sinusoidal_pos_embedding(num_positions: int, dimension: int) -> Tensor:
+    """1D sinusoidal positional embeddings as in Attention is All You Need.
+
+    Args:
+        num_positions: Number of token positions required.
+    Returns: (num_positions, dimension) position embeddings (the first dimension is the batch dimension).
+
+    """
+
+    def get_position_angle_vec(position):
+        return [position / np.power(10000, 2 * (hid_j // 2) / dimension) for hid_j in range(dimension)]
+
+    sinusoid_table = np.array([get_position_angle_vec(pos_i) for pos_i in range(num_positions)])
+    sinusoid_table[:, 0::2] = np.sin(sinusoid_table[:, 0::2])  # dim 2i
+    sinusoid_table[:, 1::2] = np.cos(sinusoid_table[:, 1::2])  # dim 2i+1
+    return torch.from_numpy(sinusoid_table).float()
+
+
+class ACTSinusoidalPositionEmbedding2d(nn.Module):
+    """2D sinusoidal positional embeddings similar to what's presented in Attention Is All You Need.
+
+    The variation is that the position indices are normalized in [0, 2π] (not quite: the lower bound is 1/H
+    for the vertical direction, and 1/W for the horizontal direction.
+    """
+
+    def __init__(self, dimension: int):
+        """
+        Args:
+            dimension: The desired dimension of the embeddings.
+        """
+        super().__init__()
+        self.dimension = dimension
+        self._two_pi = 2 * math.pi
+        self._eps = 1e-6
+        # Inverse "common ratio" for the geometric progression in sinusoid frequencies.
+        self._temperature = 10000
+
+    def forward(self, x: Tensor) -> Tensor:
+        """
+        Args:
+            x: A (B, C, H, W) batch of 2D feature map to generate the embeddings for.
+        Returns:
+            A (1, C, H, W) batch of corresponding sinusoidal positional embeddings.
+        """
+        not_mask = torch.ones_like(x[0, :1])  # (1, H, W)
+        # Note: These are like range(1, H+1) and range(1, W+1) respectively, but in most implementations
+        # they would be range(0, H) and range(0, W). Keeping it at as is to match the original code.
+        y_range = not_mask.cumsum(1, dtype=torch.float32)
+        x_range = not_mask.cumsum(2, dtype=torch.float32)
+
+        # "Normalize" the position index such that it ranges in [0, 2π].
+        # Note: Adding epsilon on the denominator should not be needed as all values of y_embed and x_range
+        # are non-zero by construction. This is an artifact of the original code.
+        y_range = y_range / (y_range[:, -1:, :] + self._eps) * self._two_pi
+        x_range = x_range / (x_range[:, :, -1:] + self._eps) * self._two_pi
+
+        inverse_frequency = self._temperature ** (
+            2 * (torch.arange(self.dimension, dtype=torch.float32, device=x.device) // 2) / self.dimension
+        )
+
+        x_range = x_range.unsqueeze(-1) / inverse_frequency  # (1, H, W, 1)
+        y_range = y_range.unsqueeze(-1) / inverse_frequency  # (1, H, W, 1)
+
+        # Note: this stack then flatten operation results in interleaved sine and cosine terms.
+        # pos_embed_x and pos_embed_y are (1, H, W, C // 2).
+        pos_embed_x = torch.stack((x_range[..., 0::2].sin(), x_range[..., 1::2].cos()), dim=-1).flatten(3)
+        pos_embed_y = torch.stack((y_range[..., 0::2].sin(), y_range[..., 1::2].cos()), dim=-1).flatten(3)
+        pos_embed = torch.cat((pos_embed_y, pos_embed_x), dim=3).permute(0, 3, 1, 2)  # (1, C, H, W)
+
+        return pos_embed
+
+
+def get_activation_fn(activation: str) -> Callable:
+    """Return an activation function given a string."""
+    if activation == "relu":
+        return f.relu
+    if activation == "gelu":
+        return f.gelu
+    if activation == "glu":
+        return f.glu
+    raise RuntimeError(f"activation should be relu/gelu/glu, not {activation}.")
