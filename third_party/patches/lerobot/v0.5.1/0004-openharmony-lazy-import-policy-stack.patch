+def _get_builtin_policy_config_class(policy_type: str) -> type[PreTrainedConfig]:
+    if policy_type not in _BUILTIN_POLICY_CONFIGS:
+        raise KeyError(policy_type)
+    module_path, class_name = _BUILTIN_POLICY_CONFIGS[policy_type]
+    module = importlib.import_module(module_path)
+    config_cls = getattr(module, class_name)
+    if not issubclass(config_cls, PreTrainedConfig):
+        raise TypeError(f"Expected {class_name} to inherit from PreTrainedConfig")
+    return config_cls
